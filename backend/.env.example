# Application
APP_NAME="TM Transportadora API"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database (Supabase / PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tm_transportadora
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/tm_transportadora

# Supabase (for direct Supabase client if needed)
SUPABASE_URL=https://jkdkspbcqnfrweanmhpp.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS — use JSON array format (required by pydantic-settings)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
