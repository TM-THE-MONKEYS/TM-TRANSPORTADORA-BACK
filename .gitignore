# ============================================================
# TM Transportadora — .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyd
*.pyo

# ── Virtual Environments ────────────────────────────────────
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ── Build / Packaging ───────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
*.egg
*.whl
MANIFEST

# ── Environment Files (NUNCA versionar .env com secrets) ────
.env
.env.*
!.env.example

# ── IDEs e Editores ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.bak
*~
.cursor/

# ── Testing & Coverage ──────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

# ── Type Checkers ───────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
pyrightconfig.json

# ── Linters / Formatters ────────────────────────────────────
.ruff_cache/

# ── Logs ────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Docker ──────────────────────────────────────────────────
.docker/

# ── Sistema Operacional ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Alembic ─────────────────────────────────────────────────
# Não ignorar versions/ — migrations devem ser versionadas

# ── Outros ──────────────────────────────────────────────────
*.sqlite3
*.db
*.pid
.sass-cache/
node_modules/
